<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SolanaWMAUnityMAUIIntegration.MainPage"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        
        <!-- Header / Wallet Card -->
        <Frame Grid.Row="0" BackgroundColor="#1e1e1e" CornerRadius="15" HasShadow="True" Padding="20" Margin="0,0,0,20">
            <VerticalStackLayout Spacing="10">
                <Label Text="My Wallet" FontSize="14" TextColor="#888888" HorizontalOptions="Center" />
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Label x:Name="AddressLabel" Text="Not Connected" FontSize="12" TextColor="White" VerticalOptions="Center" LineBreakMode="MiddleTruncation" MaximumWidthRequest="200" />
                    <ImageButton Source="dotnet_bot.png" WidthRequest="20" HeightRequest="20" Clicked="CopyAddressClicked" IsVisible="False" x:Name="CopyBtn" />
                </HorizontalStackLayout>
                <Label x:Name="BalanceLabel" Text="0.00 SOL" FontSize="36" FontAttributes="Bold" TextColor="#9945FF" HorizontalOptions="Center" />
                
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,5">
                    <Label Text="Devnet" VerticalOptions="Center" TextColor="#888888" />
                    <Switch x:Name="NetworkSwitch" IsToggled="True" Toggled="NetworkSwitch_Toggled" />
                    <Label Text="Mainnet" VerticalOptions="Center" TextColor="#888888" />
                </HorizontalStackLayout>

                <Button x:Name="ConnectBtn" Text="Connect Wallet" Clicked="ConnectWalletClicked" 
                        BackgroundColor="#14F195" TextColor="Black" CornerRadius="25" HeightRequest="50" Margin="0,10,0,0" />
            </VerticalStackLayout>
        </Frame>

        <!-- Token List -->
        <VerticalStackLayout Grid.Row="1" Spacing="10">
            <Label Text="Tokens" FontSize="18" FontAttributes="Bold" TextColor="White" Margin="0,0,0,5" />
            <CollectionView x:Name="TokensCollectionView" HeightRequest="300" SelectionMode="Single" SelectionChanged="TokensCollectionView_SelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto" Padding="10" Margin="0,5">
                            <Ellipse WidthRequest="40" HeightRequest="40" Fill="#2a2a2a" Grid.Column="0" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0">
                                <Label Text="{Binding Symbol}" TextColor="White" FontAttributes="Bold" />
                                <Label Text="{Binding Mint}" TextColor="#888888" FontSize="10" LineBreakMode="MiddleTruncation" />
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Margin="0,0,10,0">
                                <Label Text="{Binding DisplayAmount}" TextColor="White" FontAttributes="Bold" HorizontalOptions="End" />
                            </VerticalStackLayout>

                            <Button Grid.Column="3" Text="Swap" FontSize="10" HeightRequest="30" Padding="5,0"
                                    BackgroundColor="#9945FF" TextColor="White" 
                                    Clicked="TokenSwapClicked" CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No tokens found" TextColor="#444444" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50" />
                </CollectionView.EmptyView>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Actions -->
        <VerticalStackLayout Grid.Row="2" Spacing="15">
            
            <VerticalStackLayout x:Name="SendForm" IsVisible="False" Spacing="10" BackgroundColor="#1e1e1e" Padding="15" Margin="0,0,0,10">
                <Entry x:Name="RecipientEntry" Placeholder="Recipient Address" PlaceholderColor="#444444" TextColor="White" />
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                    <Entry x:Name="AmountEntry" Grid.Column="0" Placeholder="Amount (SOL)" Keyboard="Numeric" PlaceholderColor="#444444" TextColor="White" />
                    <Button Grid.Column="1" Text="Max" Clicked="MaxAmountClicked" BackgroundColor="#2a2a2a" TextColor="#14F195" Padding="10,0" HeightRequest="45" VerticalOptions="Center" />
                </Grid>
                <Button x:Name="ConfirmBtn" Text="Confirm Send" Clicked="ConfirmSendClicked" BackgroundColor="#9945FF" />
                <Button Text="Cancel" Clicked="CancelSendClicked" BackgroundColor="Transparent" TextColor="#888888" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <Button Grid.Column="0" Text="Send SOL" Clicked="SendClicked" BackgroundColor="#2a2a2a" TextColor="White" CornerRadius="10" HeightRequest="60" />
                <Button Grid.Column="1" Text="Swap" Clicked="SwapClicked" BackgroundColor="#2a2a2a" TextColor="White" CornerRadius="10" HeightRequest="60" />
            </Grid>
            
            <Label x:Name="StatusLabel" Text="Status: Idle" TextColor="#888888" HorizontalOptions="Center" FontSize="12" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
